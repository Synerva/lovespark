# Paddle Billing Configuration
# Copy this file to .env.local and fill in your actual values

# Paddle Environment
# Use 'sandbox' for testing, 'production' for live payments
VITE_PADDLE_ENVIRONMENT=sandbox

# Paddle Client Token
# Get this from Paddle Dashboard → Developer Tools → Authentication
# Format: test_xxx for sandbox, live_xxx for production
VITE_PADDLE_CLIENT_TOKEN=

# Paddle Price IDs
# Get these from Paddle Dashboard → Products → Your Product → Prices
# Format: pri_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Premium Plan Prices
VITE_PADDLE_PREMIUM_MONTHLY=
VITE_PADDLE_PREMIUM_YEARLY=

# Premium + Coaching Plan Prices
VITE_PADDLE_COACHING_MONTHLY=
VITE_PADDLE_COACHING_YEARLY=

# Example (DO NOT USE THESE - GET YOUR OWN FROM PADDLE):
# VITE_PADDLE_CLIENT_TOKEN=test_1a2b3c4d5e6f7g8h9i0j
# VITE_PADDLE_PREMIUM_MONTHLY=pri_01abc123def456ghi789jkl
# VITE_PADDLE_PREMIUM_YEARLY=pri_01mno234pqr567stu890vwx
# VITE_PADDLE_COACHING_MONTHLY=pri_01yza345bcd678efg901hij
# VITE_PADDLE_COACHING_YEARLY=pri_01klm456nop789qrs012tuv
